{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File with Debug Loki",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "args": [
                "--engine",
                "${workspaceFolder}/build/debug/bin/Loki.exe"
            ],
            "preLaunchTask": "Build Loki Debug"
        },
        {
            "name": "Python: Current File with Release Loki",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "args": [
                "--engine",
                "${workspaceFolder}/build/release/bin/Loki.exe"
            ],
            "preLaunchTask": "Build Loki Release"
        },
        {
            "name": "C++: Loki",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Loki.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build Loki Debug"
        },
        {
            "name": "C++: Loki.Tests",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/Loki.Tests.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build Loki.Tests Debug"
        }
    ]
}
