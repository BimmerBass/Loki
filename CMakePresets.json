{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "cacheVariables": {
        "LOKI_BUILD_TESTS": "ON",
        "LOKI_ENABLE_COVERAGE": "OFF"
      }
    },
    {
      "name": "gcc",
      "displayName": "GCC",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/gcc",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "LOKI_BUILD_TESTS": "ON",
        "LOKI_ENABLE_COVERAGE": "OFF"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release",
      "inherits": "gcc",
      "binaryDir": "${sourceDir}/build/gcc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "gcc-coverage",
      "displayName": "GCC Coverage",
      "inherits": "gcc",
      "cacheVariables": {
        "LOKI_ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Debug",
      "jobs": 24
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc",
      "configuration": "Release",
      "jobs": 24
    },
    {
      "name": "gcc",
      "configurePreset": "gcc",
      "jobs": 24
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release",
      "jobs": 24
    },
    {
      "name": "gcc-coverage",
      "configurePreset": "gcc-coverage",
      "jobs": 24
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc",
      "configuration": "Release"
    },
    {
      "name": "gcc",
      "configurePreset": "gcc"
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release"
    },
    {
      "name": "gcc-coverage",
      "configurePreset": "gcc-coverage"
    }
  ]
}
